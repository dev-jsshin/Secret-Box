# ============================================
# Backend 환경변수
# ============================================
# 모든 키는 application.yml의 ${ENV:default} 폴백 형태라 비워두면 default가
# 적용됩니다. 단 SPRING_DATASOURCE_*와 JWT_SECRET은 default가 없거나 dev용
# 더미라 운영 배포 전에 반드시 지정/교체하세요.

# --- Server ---
# 백엔드 리스닝 포트 (기본 6333)
SERVER_PORT=6333

# --- Database (Postgres) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/secretbox
SPRING_DATASOURCE_USERNAME=secretbox
SPRING_DATASOURCE_PASSWORD=secretbox

# --- JWT ---
# 운영 배포 시 반드시 교체. 생성: openssl rand -base64 48
JWT_SECRET=dev-secret-replace-me-with-a-long-random-string-at-least-64-chars
# 짧을수록 세션 폐기가 빨리 체감됨 (revoke된 세션이 들고있는 JWT가 만료될 때까지의 최대 딜레이).
# 폐기 즉시성이 중요하면 2~3분 권장. 길게 잡으면 폐기 효과가 그만큼 늦어진다.
JWT_ACCESS_TTL_MINUTES=2
JWT_REFRESH_TTL_DAYS=30

# --- CORS ---
# 콤마 구분. 운영에선 사설 IP 대역 빼고 실제 도메인으로 교체:
#   APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://app.example.com,https://www.example.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=

# --- SMTP (2FA 이메일 발송 — v2 기능) ---
# v1에선 사용 안 함. 비워둬도 부팅 정상.
# Gmail 사용 시 "앱 비밀번호" 발급해야 함.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=no-reply@secretbox.local
