# ============================================
# Frontend 환경변수 (선택)
# ============================================
# 모든 값은 sensible defaults가 있어 비워둬도 동작합니다.
# 사용:  cp .env.example .env.local  (Vite가 자동으로 읽음)

# 프론트 dev server 포트.
#   - 도커 운영 모드(7444)와 동시에 띄우려면 다른 포트 추천 (예: 7445)
#   - 둘 중 한 모드만 쓰면 7444 그대로 두기
VITE_PORT=7445

# Vite proxy가 /api 요청을 보낼 백엔드 주소.
#   - IDE 백엔드도 6334로 띄우면 도커 내부 6333과 겹치지 않음 (병렬 가능)
#   - 단일 모드면 http://localhost:6333 그대로
VITE_BACKEND_ORIGIN=http://localhost:6334

# 브라우저가 호출할 API base URL (기본 /api/v1, Vite proxy 경유)
# 보통 비워두면 됩니다. 프론트만 따로 배포할 때만 절대 URL 지정.
VITE_API_BASE_URL=
