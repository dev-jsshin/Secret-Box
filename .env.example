# ============================================
# SecretBox — docker-compose 전체 구성
# ============================================
# 사용:
#   cp .env.example .env
#   JWT_SECRET과 POSTGRES_PASSWORD를 교체한 뒤
#   docker compose up -d --build
#
# 실제 .env는 gitignore 되어있으니 안심하고 값 넣으셔도 됩니다.

# ---------- Postgres ----------
POSTGRES_DB=secretbox
POSTGRES_USER=secretbox
# 반드시 변경: 강한 랜덤 비밀번호
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
# 호스트 쪽에 DB 포트를 노출하고 싶을 때만 사용 (기본은 내부 네트워크 전용)
POSTGRES_PORT=5432

# ---------- JWT ----------
# 반드시 변경. 생성:  openssl rand -base64 48
JWT_SECRET=please-replace-this-with-a-64-char-random-string-generated-by-openssl
# access token 짧을수록 revoke가 빨리 체감됨 (세션 관리 UX)
JWT_ACCESS_TTL_MINUTES=2
JWT_REFRESH_TTL_DAYS=30

# ---------- CORS ----------
# LAN에서 여러 IP/도메인으로 접속 → 와일드카드 허용 (https 전용이라 안전)
# 실제 도메인만 허용할 땐: https://app.example.com,https://www.example.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://*

# ---------- 프론트엔드 노출 포트 ----------
# 호스트의 이 포트로 외부/LAN 접속 (기본 7444)
HOST_PORT=7444
