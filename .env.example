# ============================================
# Postgres (docker-compose 전용)
# ============================================
# 이 파일은 템플릿입니다.
#
# 백엔드/프론트엔드는 IDE에서 실행되므로 이 변수들을 읽지 않습니다.
# 백엔드 환경변수는 backend/.env.example 참조
# 프론트엔드 환경변수는 frontend/.env.example 참조


POSTGRES_DB=secretbox
POSTGRES_USER=secretbox
POSTGRES_PASSWORD=secretbox
POSTGRES_PORT=5432
